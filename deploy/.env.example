# ============================================================================
# OpenClaw-TradeDesk — Environment Variables
# ============================================================================
# Copy this file to .env and fill in values for your deployment.
# All variables prefixed with DEPLOY_ control workflow_dispatch behavior.
# Secrets should be set as GitHub Actions secrets, not committed here.
# ============================================================================

# ── Core Secrets (REQUIRED) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=               # Anthropic API key for all agents
OPENCLAW_GATEWAY_TOKEN=          # Gateway auth token (generate: openssl rand -hex 32)

# ── Telegram Channel ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=              # Bot token from @BotFather
TELEGRAM_USER_ID=                # Your numeric Telegram user ID

# ── Discord Channel ──────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=               # Discord bot token from Developer Portal

# ── Slack Channel ────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=                 # xoxb- bot token
SLACK_APP_TOKEN=                 # xapp- app-level token (for Socket Mode)

# ── WhatsApp Channel ─────────────────────────────────────────────────────────
# WhatsApp uses Baileys (no token needed — QR pairing on first connect)

# ── Memory / Embeddings ──────────────────────────────────────────────────────
OPENAI_API_KEY=                  # Only needed if memory_provider=openai

# ── Webhooks ─────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=                  # HMAC secret for webhook signature validation
WEBHOOK_URL=                     # External webhook endpoint URL

# ── Gateway Auth (alternative modes) ─────────────────────────────────────────
OPENCLAW_GATEWAY_PASSWORD=       # Only if auth_mode=password

# ── Telemetry ────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=     # e.g., http://localhost:4317
DATADOG_API_KEY=                 # Only if otel_exporter=datadog
GRAFANA_PUSH_URL=                # Only if otel_exporter=grafana

# ── Deployment Variant Selectors (workflow_dispatch defaults) ────────────────
# These map to GitHub Actions workflow_dispatch inputs.
# When deploying via push-to-main, the defaults below are used.
DEPLOY_CHANNELS=telegram                        # Comma-separated: telegram,discord,whatsapp,slack
DEPLOY_INSTALL_METHOD=installer                  # installer | docker
DEPLOY_GATEWAY_BIND=loopback                     # loopback | tailnet
DEPLOY_AUTH_MODE=token                           # token | password | tailscale
DEPLOY_SESSION_SCOPE=per-channel-peer            # main | per-channel-peer | per-account-channel-peer
DEPLOY_DM_POLICY=pairing                         # pairing | allowlist | open
DEPLOY_CRON_MODE=isolated                        # main | isolated
DEPLOY_MEMORY_PROVIDER=ollama                    # ollama | openai | none
DEPLOY_PROCESS_MANAGER=systemd                   # systemd | docker-compose
DEPLOY_NGINX_PROXY=false                         # true | false
DEPLOY_WEBHOOKS=false                            # true | false
DEPLOY_OTEL_EXPORTER=none                        # none | grafana | datadog | otel-collector
