{
  "channels": {
    "discord": {
      "dmPolicy": "${DM_POLICY}",
      "botToken": "${DISCORD_BOT_TOKEN}",
      "streaming": false
    }
  },
  "bindings": [
    {
      "agentId": "commander",
      "match": {
        "channel": "discord"
      }
    }
  ],
  "plugins": {
    "entries": {
      "discord": {
        "enabled": true
      }
    }
  }
}
