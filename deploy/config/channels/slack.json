{
  "channels": {
    "slack": {
      "dmPolicy": "${DM_POLICY}",
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "socketMode": true,
      "streaming": "off"
    }
  },
  "bindings": [
    {
      "agentId": "commander",
      "match": {
        "channel": "slack"
      }
    }
  ],
  "plugins": {
    "entries": {
      "slack": {
        "enabled": true
      }
    }
  }
}
